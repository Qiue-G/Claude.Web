# Server Configuration
PORT=3000
HOST=0.0.0.0

# Free-code workspace directory (mounted volume in Docker)
WORKSPACE_DIR=/workspace/projects

# Session timeout (ms)
SESSION_TIMEOUT=3600000

# Max concurrent sessions
MAX_SESSIONS=10

# ============================================================
# 安全配置（必填！缺少以下配置服务将拒绝启动）
# ============================================================

# JWT 签名密钥 — 至少 32 字节随机 hex
# 生成命令: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-jwt-secret-here

# API Key 加密密钥 — 至少 32 字节随机 hex
# 生成命令: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-encryption-key-here

# 管理后台 API 令牌（可选，不设置则管理 API 不可用）
ADMIN_TOKEN=your-admin-token

# ============================================================
# RAG / 知识库（可选）
# ============================================================

# Embedding API Key（RAG 功能依赖）
# OPENAI_API_KEY=sk-xxx

# Embedding API Base URL（支持任何 OpenAI 兼容端点）
# OPENAI_BASE_URL=https://api.openai.com/v1

# 向量存储类型: memory（默认）| qdrant
# VECTOR_STORE_TYPE=memory

# Qdrant 配置（VECTOR_STORE_TYPE=qdrant 时需要）
# VECTOR_STORE_QDRANT_URL=http://localhost:6333
# VECTOR_STORE_QDRANT_API_KEY=xxx

# ============================================================
# MCP 服务器（可选，JSON 格式）
# ============================================================

# MCP_SERVERS=[{"name":"example","command":"node","args":["server.js"]}]

# ============================================================
# 部署相关
# ============================================================

# CORS 白名单（逗号分隔，生产环境自动读取 RAILWAY_PUBLIC_DOMAIN）
# ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# 启用详细健康检查端点（生产环境建议关闭）
# ENABLE_DETAILED_HEALTH=false
