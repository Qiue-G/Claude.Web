{
  "name": "free-code-web",
  "version": "1.0.0",
  "description": "Web interface for free-code CLI",
  "type": "module",
  "scripts": {
    "dev": "node src/server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "test": "node --test test/*.test.js",
    "test:vitest": "vitest run",
    "test:all": "node --test test/*.test.js && vitest run",
    "start": "cross-env NODE_ENV=production node src/server/index.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "diff": "^9.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "highlight.js": "^11.11.1",
    "html-to-text": "^10.0.0",
    "lodash.get": "^4.4.2",
    "marked": "^18.0.5",
    "pdf-parse": "^2.4.5",
    "sql.js": "^1.14.1",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "fake-indexeddb": "^6.2.5",
    "svelte": "^5.56.4",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
