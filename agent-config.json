{
  "defaults": {
    "provider": "openrouter",
    "model": "nvidia/nemotron-3-ultra-550b-a55b:free"
  },
  "providers": {
    "openrouter": {
      "baseUrl": "https://openrouter.ai/api/v1/chat/completions",
      "fallbackModel": "nvidia/nemotron-3-super-120b-a12b:free",
      "modelAliases": {
        "haiku":    "anthropic/claude-haiku-4.5",
        "sonnet":   "anthropic/claude-sonnet-4",
        "opus":     "anthropic/claude-opus-4",
        "haiku35":  "anthropic/claude-3.5-haiku",
        "sonnet35": "anthropic/claude-3.5-sonnet",
        "sonnet37": "anthropic/claude-3.7-sonnet"
      },
      "models": [
        { "id": "nvidia/nemotron-3-ultra-550b-a55b:free",    "name": "NVIDIA Nemotron 550B",    "tier": "free", "context": 128000 },
        { "id": "deepseek/deepseek-chat-v3-0324:free",        "name": "DeepSeek V3",            "tier": "free", "context": 131072 },
        { "id": "meta-llama/llama-4-maverick:free",           "name": "Llama 4 Maverick",       "tier": "free", "context": 131072 },
        { "id": "anthropic/claude-haiku-4.5",                 "name": "Claude Haiku 4.5",       "tier": "paid", "context": 200000 },
        { "id": "anthropic/claude-sonnet-4",                  "name": "Claude Sonnet 4",        "tier": "paid", "context": 200000 },
        { "id": "anthropic/claude-opus-4",                    "name": "Claude Opus 4",          "tier": "paid", "context": 200000 },
        { "id": "google/gemini-2.5-pro",                      "name": "Gemini 2.5 Pro",         "tier": "paid", "context": 1048576 },
        { "id": "openai/gpt-4.1",                             "name": "GPT-4.1",               "tier": "paid", "context": 1000000 }
      ]
    },
    "deepseek": {
      "baseUrl": "https://api.deepseek.com/v1",
      "fallbackModel": "deepseek-chat",
      "modelAliases": {},
      "models": [
        { "id": "deepseek-chat",     "name": "DeepSeek Chat (V3)",    "tier": "paid", "context": 65536 },
        { "id": "deepseek-reasoner", "name": "DeepSeek Reasoner (R1)","tier": "paid", "context": 65536 }
      ]
    },
    "anthropic": {
      "baseUrl": "https://api.anthropic.com/v1/messages",
      "fallbackModel": null,
      "modelAliases": {},
      "models": [
        { "id": "claude-sonnet-4-20250514",      "name": "Claude Sonnet 4",       "tier": "paid", "context": 200000 },
        { "id": "claude-3-5-haiku-20241022",     "name": "Claude Haiku 3.5",      "tier": "paid", "context": 200000 },
        { "id": "claude-opus-4-20250514",        "name": "Claude Opus 4",         "tier": "paid", "context": 200000 },
        { "id": "claude-3-5-sonnet-20241022",    "name": "Claude Sonnet 3.5",     "tier": "paid", "context": 200000 }
      ]
    },
    "openai": {
      "baseUrl": "https://api.openai.com/v1/chat/completions",
      "fallbackModel": null,
      "modelAliases": {},
      "models": [
        { "id": "gpt-4o",        "name": "GPT-4o",         "tier": "paid", "context": 128000 },
        { "id": "gpt-4o-mini",   "name": "GPT-4o Mini",    "tier": "paid", "context": 128000 },
        { "id": "gpt-4.1",       "name": "GPT-4.1",        "tier": "paid", "context": 1000000 },
        { "id": "o3-mini",       "name": "o3-mini",         "tier": "paid", "context": 200000 }
      ]
    }
  },
  "filters": {
    "contextInject": {
      "enabled": true,
      "topK": 3,
      "bm25Weight": 0.3,
      "enableRerank": false,
      "enableCrossEncoder": false,
      "enableEnrichment": true,
      "enableRewrite": false,
      "rewriteConfig": {
        "enabled": false,
        "url": "",
        "apiKey": "",
        "model": "gpt-4o-mini"
      },
      "rerankConfig": {
        "url": "",
        "apiKey": "",
        "model": "rerank-v3.5"
      },
      "minScore": 0.0,
      "maxContextLength": 2000,
      "minQueryLength": 10,
      "autoInject": true,
      "ignoreToolMessages": true
    },
    "profanity": {
      "enabled": true,
      "action": "warn",
      "logOnly": true,
      "customWords": []
    },
    "formatGuard": {
      "enabled": true,
      "maxLength": 10000,
      "action": "fix",
      "requireChinese": false,
      "stripCodeFences": true
    }
  },
  "toolPolicies": {
    "default": "prompt",
    "read_file": "auto",
    "list_files": "auto",
    "glob": "auto",
    "grep": "auto",
    "todo_write": "auto",
    "web_search": "auto",
    "code_interpreter": "prompt",
    "write_file": "prompt",
    "edit_file": "prompt",
    "delete_file": "prompt",
    "rename_file": "prompt",
    "comment": "auto = 自动批准不弹窗, prompt = 弹窗确认, deny = 自动拒绝"
  },
  "fileSandbox": {
    "enabled": true,
    "comment": "限制文件工具只能操作 WORKSPACE_DIR 下的路径"
  },
  "plugins": {
    "starlight": {
      "enabled": true,
      "type": "theme",
      "manifest": {
        "name": "星夜主题",
        "description": "深紫星夜配色方案",
        "tokens": {
          "light": {
            "--ds-accent": "#7a5fd0",
            "--ds-accent-soft": "rgba(122, 95, 208, 0.15)",
            "--ds-selection": "rgba(122, 95, 208, 0.2)"
          },
          "dark": {
            "--ds-accent": "#a78ff0",
            "--ds-accent-soft": "rgba(167, 143, 240, 0.2)",
            "--ds-selection": "rgba(167, 143, 240, 0.26)"
          }
        },
        "toolbarButtons": [
          { "slot": "right", "label": "切换星夜", "icon": "star", "command": "starlight:toggle" }
        ],
        "commands": [
          { "id": "starlight:toggle", "name": "切换星夜主题", "description": "启用/禁用星夜主题配色", "shortcut": "" }
        ]
      }
    },
    "prompt-enhancer": {
      "enabled": true,
      "type": "hook",
      "hooks": {
        "onUserPrompt": {
          "instruction": "请用中文回答，如果涉及代码请用英文注释"
        },
        "postToolUse": {
          "matcher": "web_search",
          "instruction": "用中文总结搜索结果要点"
        }
      }
    }
  }
}
